# Environment variables for Metalpro Next.js application
# Copy this file to .env.local for local development
# For production, set these variables in your hosting platform (Timeweb, Vercel, etc.)

# Next.js public variables (available in browser)
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your_yandex_maps_api_key_here
NEXT_PUBLIC_BASE_PATH= # Optional: set if deploying to subdirectory (e.g., /metalpro-next)

# Next.js build configuration
NEXT_EXPORT=false # Set to true for static export
ANALYZE=false # Set to true for bundle analysis

# API endpoints (if any)
NEXT_PUBLIC_API_URL=https://api.example.com
# Note: Forms now use direct HTML forms with action="https://formsubmit.co/nezabut123@gmail.com"
# No server-side environment variable needed

# Security (optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
NEXT_PUBLIC_YANDEX_METRICA_ID=XXXXXXXX

# Application settings
NEXT_PUBLIC_SITE_NAME=Стиль Мастер
NEXT_PUBLIC_SITE_URL=https://stylmaster.example.com
NEXT_PUBLIC_CONTACT_PHONE=+7 (XXX) XXX-XX-XX
NEXT_PUBLIC_CONTACT_EMAIL=info@stylmaster.example.com

# Telegram Bot Configuration (server-side only)
# Create a bot via @BotFather and get the token
# Get your chat ID by sending a message to @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# FormSubmit Configuration (optional)
FORM_SUBMIT_RECIPIENT_EMAIL=nezabut123@gmail.com

# SMTP Yandex Mail Configuration (for email notifications)
# Get app password from https://id.yandex.ru/security/app-passwords
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your-yandex-email@yandex.ru
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yandex.ru
EMAIL_RECIPIENT=nezabut123@gmail.com

# Note: Variables without NEXT_PUBLIC_ prefix are server-side only
# and should be set in the hosting environment.