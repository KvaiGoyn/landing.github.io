# Отключаем аудит безопасности при установке (ускоряет npm ci)
audit=false

# Отключаем сбор средств (fund) при установке
fund=false

# Включаем генерацию package-lock.json (требуется для npm ci в Docker)
package-lock=true

# Не показывать уведомления о новых версиях npm
update-notifier=false

# Использовать только lock-файл для детерминированных установок
prefer-offline=false